rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - readingGoal: number
    //   - createdAt: timestamp
    //
    // Collection: books
    // Document ID: {bookId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - authors: list
    //   - description: string
    //   - coverUrl: string
    //   - pageCount: number
    //   - categories: list
    //
    // Collection: reading_progress
    // Document ID: {progressId}
    // Fields:
    //   - uid: string (required)
    //   - bookId: string (required)
    //   - status: string (reading, completed, wishlist)
    //   - currentPage: number
    //   - totalPages: number
    //   - startedAt: timestamp
    //   - finishedAt: timestamp
    //
    // Collection: reviews
    // Document ID: {reviewId}
    // Fields:
    //   - uid: string (required)
    //   - bookId: string (required)
    //   - rating: number
    //   - review: string
    //   - createdAt: timestamp
    //
    // Collection: recommendation_feedback
    // Document ID: {feedbackId}
    // Fields:
    //   - uid: string (required)
    //   - bookId: string (required)
    //   - bookTitle: string
    //   - type: string (up, down)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['uid', 'bookId', 'status']) &&
             data.uid == request.auth.uid &&
             data.status in ['reading', 'completed', 'wishlist'];
    }

    function isValidReview(data) {
      return data.keys().hasAll(['uid', 'bookId', 'rating']) &&
             data.uid == request.auth.uid &&
             data.rating >= 0 && data.rating <= 5;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['uid', 'bookId', 'type']) &&
             data.uid == request.auth.uid &&
             data.type in ['up', 'down'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /books/{bookId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Cache metadata
    }

    match /reading_progress/{progressId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidProgress(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidReview(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /recommendation_feedback/{feedbackId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
      allow update, delete: if false;
    }
  }
}
